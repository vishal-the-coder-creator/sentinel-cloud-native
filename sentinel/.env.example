KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_RAW_TOPIC=raw-messages
KAFKA_PROCESSED_TOPIC=processed-messages
KAFKA_ALERTS_TOPIC=alerts
KAFKA_PRODUCER_RETRIES=5
KAFKA_PRODUCER_RETRY_BACKOFF_MS=2000
KAFKA_CONSUMER_POLL_MS=1000

MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=sentinel
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

REDIS_URL=redis://redis:6379/0

SENTINEL_KEYWORDS=ai,error,warning,fail,success,outage,latency,incident
SENTIMENT_PROVIDER=textblob
SENTIMENT_MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english

ALERT_KEYWORD=error
ALERT_THRESHOLD=5
ALERT_WINDOW_MINUTES=10

CORS_ORIGIN=*
PORT=8000

VITE_GATEWAY_HTTP_URL=http://localhost:8000
VITE_GATEWAY_WS_URL=ws://localhost:8000/ws

