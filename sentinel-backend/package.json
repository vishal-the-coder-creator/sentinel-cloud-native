{
  "name": "sentinel-backend",
  "version": "1.0.0",
  "private": true,
  "description": "FastAPI backend service for ingesting messages and returning analytics",
  "scripts": {
    "start": "py -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "dev": "py -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "install:py": "py -m pip install -r requirements.txt"
  }
}
